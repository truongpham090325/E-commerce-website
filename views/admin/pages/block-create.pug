extends ../layouts/default.pug

block main
  .card
    .card-header
      .row.align-items-center
        .col
          h4.card-title #{pageTitle}
    .card-body.pt-0
      form(id="blockCreateForm")
        .row
          .col-md-12
            .mb-3
              label.form-label(for="name") Tên block *
              input.form-control(id="name" type="text" name="name")
          .col-md-6
            .mb-3
              label.form-label(for="fileName") File giao diện *
              select.form-select(name="fileName" id="fileName")
                option(value="") - Chọn file giao diện --
                each file in fileList
                  option(value=file) #{file}
          .col-md-6
            .mb-3
              label.form-label(for="status") Trạng thái
              select.form-select(id="status" name="status")
                option(value="active") Hoạt động
                option(value="inactive") Tạm dừng
          .col-md-12
            .mb-3
              label.form-label(for="data") Dữ liệu block (Dữ liệu dạng JSON)
              div(json-editor style="height: 500px")
        button.btn.btn-primary(type="submit") Tạo mới
        a.btn.btn-danger.ms-1(href=`/${pathAdmin}/block/list`) Hủy