extends ../layouts/default.pug
include ../mixins/form-search.pug
include ../mixins/pagination.pug

block main
  .card-header(bis_skin_checked="1")
    .row.align-items-center.mb-1(bis_skin_checked="1")
      .col(bis_skin_checked="1")
        h4.card-title #{pageTitle}
      // end col
      .col-auto(bis_skin_checked="1")
          a.btn.btn-danger.me-1(
            href=`/${pathAdmin}/blog/category/trash`
            )
            i.far.fa-trash-alt.me-1
            | Thùng rác
          a.btn.btn-primary(
            href=`/${pathAdmin}/blog/category/create`
            )
            i.fa-solid.fa-plus.me-1
            | Tạo danh mục
      // end col
    // end row

  .card-body.pt-0(bis_skin_checked="1")
    //- Search
    .row
      .col-lg-6
        +form-search()
    //- Table
    .table-responsive(bis_skin_checked="1")
      table.table.table-striped.mb-0
        thead.table-light
          tr
            th STT
            th Avatar
            th Tên bài viết
            th Trạng thái
            th Lượt xem
            th.text-end Hành động
        tbody
          each item, index in blogList
            tr
              td #{pagination.skip+index+1}
              td
                if(item.avatar)
                  img(
                    src=`${domainCDN}${item.avatar}`
                    class="rounded thumb-md me-1 d-inline"
                  )
              td #{item.name}
              td
                if (item.status == "draft")
                  span.badge.bg-warning Bản nháp
                else if(item.status == "published")
                  span.badge.bg-primary Đã xuất bản
                else if(item.status == "archived")
                  span.badge.bg-danger Đã lưu trữ
              td #{item.view}
              td.text-end
                a(href=`/${pathAdmin}/blog/edit/${item.id}`)
                  i.las.la-pen.text-secondary.font-16.fs-20
                a(
                  href="javascript:;"
                  button-api
                  data-method="PATCH"
                  data-api=`/${pathAdmin}/blog/delete/${item.id}`
                  )
                  i.las.la-trash-alt.text-secondary.font-16.fs-20
      // end /table
    //- Pagination
    +pagination()
