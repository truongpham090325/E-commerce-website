extends ../layouts/default.pug
include ../mixins/form-search.pug
include ../mixins/pagination.pug

block main
  .card-header(bis_skin_checked="1")
    .row.align-items-center.mb-1(bis_skin_checked="1")
      .col(bis_skin_checked="1")
        h4.card-title #{pageTitle}
      // end col
      .col-auto(bis_skin_checked="1")
          a.btn.btn-danger.me-1(
            href=`/${pathAdmin}/role/trash`
            )
            i.far.fa-trash-alt.me-1
            | Thùng rác
          a.btn.btn-primary(
            href=`/${pathAdmin}/role/create`
            )
            i.fa-solid.fa-plus.me-1
            | Tạo nhóm quyền
      // end col
    // end row

  .card-body.pt-0(bis_skin_checked="1")
    //- Search
    .row
      .col-lg-6
        +form-search()
    //- Table
    .table-responsive(bis_skin_checked="1")
      table.table.table-striped.mb-0
        thead.table-light
          tr
            th STT
            th Tên nhóm quyền
            th Mô tả
            th Trạng thái
            th.text-end Hành động
        tbody
          each item, index in roleList
            tr
              td #{pagination.skip+index+1}
              td #{item.name}
              td #{item.description}
              td
                if (item.status == "active")
                  span.badge.bg-primary Hoạt động
                else if(item.status == "published")
                  span.badge.bg-danger Tạm dừng
              td.text-end
                a(href=`/${pathAdmin}/role/edit/${item.id}`)
                  i.las.la-pen.text-secondary.font-16.fs-20
                a(
                  href="javascript:;"
                  button-api
                  data-method="PATCH"
                  data-api=`/${pathAdmin}/role/delete/${item.id}`
                  )
                  i.las.la-trash-alt.text-secondary.font-16.fs-20
      // end /table
    //- Pagination
    +pagination()
