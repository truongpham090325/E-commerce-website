extends ../layouts/default.pug

block main
  .row
    .col-12
      .card
        .card-header
          .row.align-items-center
            .col
              h4.card-title #{pageTitle}
            // end col
            .col-auto(bis_skin_checked="1")
              a.btn.btn-info(
                href=`/${pathAdmin}/order/list`
                )
                i.fas.fa-arrow-left.me-1
                | Quay lại danh sách
            // end col
          // end row
        // end card-header
        .card-body.pt-0
          //- Table
          .table-responsive
            table.table.table-striped.mb-0
              thead.table-light
                tr
                  th STT
                  th Mã đơn
                  th Khách hàng
                  th Tổng tiền
                  th Thanh toán
                  th TT thanh toán
                  th TT đơn hàng
                  th Ngày tạo
                  th.text-end Hành động
              tbody
                each item, index in orderList
                  tr
                    td #{index + 1}
                    td
                      b #{item.code}
                    td
                      div #{item.fullName}
                      small.text-muted #{item.phone}
                    td
                      b.text-danger #{item.total.toLocaleString('vi-VN')} đ
                    td
                      case item.paymentMethod
                        when "money"
                          span.badge.bg-secondary Tiền mặt
                        when "vnpay"
                          span.badge.bg-danger VNPay
                        when "zalopay"
                          span.badge.bg-primary ZaloPay
                    td
                      case item.paymentStatus
                        when "unpaid"
                          span.badge.bg-warning Chưa thanh toán
                        when "paid"
                          span.badge.bg-success Đã thanh toán
                        when "refunded"
                          span.badge.bg-info Đã hoàn tiền
                    td
                      case item.orderStatus
                        when "pending"
                          span.badge.bg-secondary Chờ xác nhận
                        when "confirmed"
                          span.badge.bg-primary Đã xác nhận
                        when "shipping"
                          span.badge.bg-info Đang giao
                        when "completed"
                          span.badge.bg-success Giao thành công
                        when "cancelled"
                          span.badge.bg-danger Đã hủy
                        when "returned"
                          span.badge.bg-dark Đã trả hàng
                    td
                      | #{item.createdAt.toLocaleString('vi-VN')}
                    td.text-end
                      a(
                        href="javascript:;"
                        button-api
                        data-method="PATCH"
                        data-api=`/${pathAdmin}/order/undo/${item.id}`
                        )
                        i.fas.fa-undo-alt.text-secondary.font-16.fs-20
                      a(
                        href="javascript:;"
                        button-api
                        data-method="DELETE"
                        data-api=`/${pathAdmin}/order/destroy/${item.id}`
                        )
                        i.las.la-trash-alt.text-secondary.font-16.fs-20
    // end col