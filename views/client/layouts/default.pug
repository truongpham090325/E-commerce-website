doctype html
html(lang="vi")
  head
    meta(charset="UTF-8")
    meta(
      content="width=device-width, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0, user-scalable=no, target-densityDpi=device-dpi" 
      name="viewport"
      )
    
    //- SEO cơ bản  
    title #{seo ? seo.title : pageTitle}
    meta(name="description" content=(seo ? seo.description : ""))
    meta(name="keywords" content=(seo && seo.keywords.length > 0 ? seo.keywords.join(", ") : ""))

    //- Robots
    meta(
      name="robots",
      content=`${seo && seo.robots.index ? 'index' : 'noindex'}, ${seo && seo.robots.follow ? 'follow' : 'nofollow'}`
    )

    //- Open Graph
    meta(property="og:title" content=(seo ? seo.og.title : ""))
    meta(property="og:description" content=(seo ? seo.og.description : ""))
    meta(property="og:image" content=(seo && seo.og.image ? `${domainCDN}${seo.og.image}` : ""))

    
    //- Tránh duplicate content (Google index đúng URL)
    link(rel="canonical" href=canonicalUrl)

    script.
      const domainCDN = "#{domainCDN}"
    link(
      href=`/client/assets/images/favicon.png?v=${assetVersion}` 
      type="image/png" 
      rel="icon"
      )
    link(
      href=`/client/assets/css/all.min.css?v=${assetVersion}` 
      rel="stylesheet"
      )
    link(
      href=`/client/assets/css/bootstrap.min.css?v=${assetVersion}` 
      rel="stylesheet"
      )
    link(
      href=`/client/assets/css/animate.css?v=${assetVersion}` 
      rel="stylesheet"
      )
    link(
      href=`/client/assets/css/mobile_menu.css?v=${assetVersion}` 
      rel="stylesheet"
      )
    link(
      href=`/client/assets/css/nice-select.css?v=${assetVersion}` 
      rel="stylesheet"
      )
    link(
      href=`/client/assets/css/scroll_button.css?v=${assetVersion}` 
      rel="stylesheet"
      )
    link(
      href=`/client/assets/css/slick.css?v=${assetVersion}` 
      rel="stylesheet"
      )
    link(
      href=`/client/assets/css/venobox.min.css?v=${assetVersion}` 
      rel="stylesheet"
      )
    link(
      href=`/client/assets/css/select2.min.css?v=${assetVersion}` 
      rel="stylesheet"
      )
    link(
      href=`/client/assets/css/jquery.pwstabs.css?v=${assetVersion}` 
      rel="stylesheet"
      )
    link(
      href=`/client/assets/css/range_slider.css?v=${assetVersion}` 
      rel="stylesheet"
      )
    link(
      href=`/client/assets/css/multiple-image-video.css?v=${assetVersion}` 
      rel="stylesheet"
      )
    link(
      href=`/client/assets/css/custom_spacing.css?v=${assetVersion}` 
      rel="stylesheet"
      )
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/notyf@3/notyf.min.css">
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/openlayers@4.6.5/dist/ol.min.css")
    link(
      href=`/client/assets/css/style.css?v=${assetVersion}` 
      rel="stylesheet"
      )
    link(
      href=`/client/assets/css/responsive.css?v=${assetVersion}` 
      rel="stylesheet"
      )
  body(class="default_home")
