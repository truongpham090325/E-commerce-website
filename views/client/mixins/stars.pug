mixin stars(item)
  - const ratingAvg = item.ratingAvg || 0;
  - const fullStar = Math.floor(ratingAvg); // 4.5 => 4
  - const hasHalfStar = ratingAvg - fullStar >= 0.5; // true or false

  - for(let i = 1; i <= 5; i++)
    if (i <= fullStar)
      i.fas.fa-star
    else if ((i == fullStar + 1) && hasHalfStar)
      i.fas.fa-star-half-alt
    else
      i.far.fa-star