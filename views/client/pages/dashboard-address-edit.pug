
extends ../layouts/default.pug
include ../mixins/page-banner.pug

block main
  //
    =========================
    PAGE BANNER START
    ==========================
  +page-banner(
    {
      name: pageTitle,
    },
    `/dashboard/address/edit/${addressDetail.id}`
  )
  //
    =========================
    PAGE BANNER START
    ==========================

  //
    ============================
    DSHBOARD START
    =============================
  section.dashboard(class="mb_100")
    .container
      .row
        .col-xl-3.wow.fadeInUp
          include ../partials/dashboard-sidebar.pug
        .col-xl-9.wow.fadeInRight
          div(class="dashboard_content mt_100")
            h3(class="dashboard_title")
              | #{pageTitle}
              a(
                href="/dashboard/address" 
                class="common_btn cancel_edit"
                ) Hủy
            div(class="dashboard_profile_info_edit")
              form(class="info_edit_form" id="dashboardAddressEditForm")
                .row
                  .col-md-6.d-none
                    div(class="single_input")
                      label(for="id") Id *
                      input(
                        type="text"
                        name="id"
                        id="id"
                        value=addressDetail.id
                        )
                  .col-md-6
                    div(class="single_input")
                      label(for="fullName") Họ tên *
                      input(
                        placeholder="Ví dụ: Lê Văn A" 
                        type="text"
                        name="fullName"
                        id="fullName"
                        value=addressDetail.fullName
                        )
                  .col-md-6
                    div(class="single_input")
                      label(for="phone") Số điện thoại *
                      input(
                        placeholder="Ví dụ: 0987654321" 
                        type="text"
                        name="phone"
                        id="phone"
                        value=addressDetail.phone
                        )
                  .col-md-12
                    label Chọn địa chỉ trên bản đồ *
                    div(class="input-group")
                      input(
                        class="form-control" 
                        placeholder="Nhập địa chỉ cần tìm..." 
                        type="text"
                        id="mapSearchInput"
                        )
                      span(
                        class="btn btn-outline-secondary"
                        id="mapSearchBtn"
                        ) Tìm kiếm
                    div(id="boxMap" style="height: 350px; margin-bottom: 25px;")
                  .col-md-12
                    div(class="single_input")
                      label(for="address") Địa chỉ *
                      input(
                        type="text" 
                        name="address" 
                        id="address"
                        value=addressDetail.address
                        )
                  .col-md-6.d-none
                    div(class="single_input")
                      label(for="longitude") Kinh độ *
                      input(
                        type="text" 
                        name="longitude" 
                        id="longitude"
                        value=addressDetail.longitude
                        )
                  .col-md-6.d-none
                    div(class="single_input")
                      label(for="latitude") Vĩ độ *
                      input(
                        type="text" 
                        name="latitude" 
                        id="latitude"
                        value=addressDetail.latitude
                        )
                  .col-md-6
                    div(class="form-check" style="margin-bottom: 25px")
                      input(
                        class="form-check-input" 
                        type="checkbox" 
                        name="isDefault" 
                        id="isDefault"
                        style="padding: 0"
                        checked=addressDetail.isDefault
                        )
                      label(class="form-check-label" for="isDefault") Đặt làm địa chỉ mặc định
                  .col-md-12
                    button(
                      class="common_btn" 
                      type="submit"
                      )
                      | Cập nhật
                      i.fas.fa-long-arrow-right
  //
    ============================
    DSHBOARD END
    =============================