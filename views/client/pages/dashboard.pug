extends ../layouts/default.pug
include ../mixins/page-banner.pug

block main
  //
    =========================
    PAGE BANNER START
    ==========================
  +page-banner(
    {
      name: pageTitle
    },
    "/dashboard"
  )
  //
    =========================
    PAGE BANNER START
    ==========================

  //
    ============================
    DSHBOARD START
    =============================
  section.dashboard(class="mb_100")
    .container
      .row
        .col-xl-3.wow.fadeInUp
          include ../partials/dashboard-sidebar.pug
        .col-xl-9.wow.fadeInRight
          div(class="dashboard_content mt_100")
            h3(class="dashboard_title mb-4")
              | #{pageTitle}
            .row
              .col-xl-4.col-md-6.wow.fadeInUp
                div(class="dashboard_overview_item")
                  .icon
                    svg.size-6(
                      stroke="currentColor" 
                      stroke-width="1.5" 
                      viewBox="0 0 24 24" 
                      fill="none" 
                      xmlns="http://www.w3.org/2000/svg"
                      )
                      path(
                        d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z" 
                        stroke-linejoin="round" 
                        stroke-linecap="round"
                        )
                  h3
                    | #{totalOrders.toLocaleString("vi-VN")}
                    span Tổng đơn hàng
              .col-xl-4.col-md-6.wow.fadeInUp
                .blue(class="dashboard_overview_item")
                  .icon
                    svg.size-6(
                      stroke="currentColor" 
                      stroke-width="1.5" 
                      viewBox="0 0 24 24" 
                      fill="none" 
                      xmlns="http://www.w3.org/2000/svg"
                      )
                      path(
                        d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" 
                        stroke-linejoin="round" 
                        stroke-linecap="round"
                        )
                  h3
                    | #{totalCompletedOrders.toLocaleString("vi-VN")}
                    span Giao thành công
              .col-xl-4.col-md-6.wow.fadeInUp
                .olive(class="dashboard_overview_item")
                  .icon
                    svg.size-6(
                      stroke="currentColor" 
                      stroke-width="1.5" 
                      viewBox="0 0 24 24" 
                      fill="none" 
                      xmlns="http://www.w3.org/2000/svg"
                      )
                      path(
                        d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" 
                        stroke-linejoin="round" 
                        stroke-linecap="round"
                        )
                  h3
                    | #{totalReviews.toLocaleString("vi-VN")}
                    span Tổng số đánh giá
            .row(class="mt_25")
              .col-xl-12.wow.fadeInLeft
                div(class="dashboard_recent_order")
                  h3 Đơn hàng gần đây của bạn
                  div(class="dashboard_order_table")
                    .table-responsive
                      table
                        thead
                          tr
                            th Mã ĐH
                            th Ngày đặt
                            th Tổng tiền
                            th PTTT
                            th Trạng thái
                            th Hành động
                        tbody
                          each order in orderList
                            tr
                              td #{order.code}
                              td #{order.createdAt.toLocaleString("vi-VN")}
                              td #{order.total.toLocaleString("vi-VN")}đ
                              td
                                case order.paymentMethod
                                  when "money"
                                    | Tiền mặt
                                  when "vnpay"
                                    | VNPay
                                  when "zalopay"
                                    | ZaloPay
                              td
                                div Thanh toán: 
                                  case order.paymentStatus
                                    when "unpaid"
                                      | Chưa thanh toán
                                    when "paid"
                                      | Đã thanh toán
                                    when "refunded"
                                      | Đã hoàn tiền
                                div Đơn hàng: 
                                  case order.orderStatus
                                    when "pending"
                                      | Chờ xác nhận
                                    when "confirmed"
                                      | Đã xác nhận
                                    when "shipping"
                                      | Đang giao
                                    when "completed"
                                      | Giao thành công
                                    when "cancelled"
                                      | Đã hủy
                                    when "returned"
                                      | Đã trả hàng
                              td
                                a(href=`/dashboard/order/detail/${order.id}`)
                                  svg.size-6(
                                    stroke="currentColor" 
                                    stroke-width="1.5" 
                                    viewBox="0 0 24 24" 
                                    fill="none" 
                                    xmlns="http://www.w3.org/2000/svg"
                                    )
                                    path(
                                      d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" 
                                      stroke-linejoin="round" 
                                      stroke-linecap="round"
                                      )
                                    path(
                                      d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" 
                                      stroke-linejoin="round" 
                                      stroke-linecap="round"
                                      )
                                  | Xem chi tiết
                                a(
                                  href=`/dashboard/order/review/${order.id}`
                                  class="review_order"
                                  )
                                  svg.size-6(
                                    stroke="currentColor" 
                                    stroke-width="1.5" 
                                    viewBox="0 0 24 24" 
                                    fill="none" 
                                    xmlns="http://www.w3.org/2000/svg"
                                    )
                                    path(
                                      d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 0 1-2.555-.337A5.972 5.972 0 0 1 5.41 20.97a5.969 5.969 0 0 1-.474-.065 4.48 4.48 0 0 0 .978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25Z" 
                                      stroke-linejoin="round" 
                                      stroke-linecap="round"
                                      )
                                  | Đánh giá