extends ../layouts/default.pug
include ../mixins/page-banner.pug

block main
  //
    =========================
    PAGE BANNER START
    ==========================
  +page-banner(
    {
      name: pageTitle,
    },
    "/dashboard/address"
  )
  //
    =========================
    PAGE BANNER START
    ==========================

  //
    ============================
    DSHBOARD START
    =============================
  section.dashboard(class="mb_100")
    .container
      .row
        .col-xl-3.wow.fadeInUp
          include ../partials/dashboard-sidebar.pug
        .col-xl-9.wow.fadeInRight
          div(class="dashboard_content mt_100")
            h3(class="dashboard_title")
              | #{pageTitle}
              a(
                href="/dashboard/address/create"
                class="common_btn"
                ) Thêm địa chỉ
            div(class="checkout_address_area")
              .row
                each item in addressList
                  .col-md-6
                    div(class="checkout_single_address")
                      if (item.isDefault)
                        .inner-info.text-success
                          <i class="fas fa-check-circle"></i>
                          | Mặc định
                      .inner-info
                        <i class="fas fa-address-card"></i>
                        | #{item.fullName}
                      .inner-info
                        <i class="fas fa-phone"></i>
                        | #{item.phone}
                      .inner-info
                        <i class="fas fa-map-marker-alt"></i>
                        | #{item.address}
                      .inner-info
                        if (!item.isDefault)
                          a(
                            class="btn btn-primary" 
                            href="javascript:;" 
                            button-api 
                            data-method="PATCH"
                            data-api=`/dashboard/address/change-default/${item.id}`
                            ) Đặt mặc định
                        <a class="btn btn-warning" href="#">Sửa</a>
                        a(
                          class="btn btn-danger" 
                          href="javascript:;"
                          button-api 
                          data-method="DELETE"
                          data-api=`/dashboard/address/delete/${item.id}`
                          ) Xóa
  //
    ============================
    DSHBOARD END
    =============================